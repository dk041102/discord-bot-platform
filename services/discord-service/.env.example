# --- Discord application credentials (Developer Portal > your app) ---
# General Information tab:
DISCORD_PUBLIC_KEY=your_public_key_hex_here
DISCORD_APPLICATION_ID=your_application_id_here
# Bot tab > Reset Token:
DISCORD_BOT_TOKEN=your_bot_token_here

# --- Database (Neon / Supabase connection string, free tier) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Optional: AI triage stretch goal ---
# Leave unset to disable the AI step entirely with zero impact on core flow.
AI_SERVICE_URL=http://localhost:3002

# --- Server ---
PORT=3001
